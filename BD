-- PRESTAMOS: calculo, cuotas y acuerdo digital


ALTER TABLE prestamos
ADD COLUMN cuotas INT NULL AFTER estado,
ADD COLUMN interes_anual DOUBLE NULL AFTER cuotas,
ADD COLUMN cuota_mensual DOUBLE NULL AFTER interes_anual,
ADD COLUMN total_pagar DOUBLE NULL AFTER cuota_mensual,
ADD COLUMN acuerdo_digital TEXT NULL AFTER total_pagar,
ADD COLUMN estado_acuerdo VARCHAR(50) NULL AFTER acuerdo_digital,
ADD COLUMN fecha_firma DATETIME NULL AFTER estado_acuerdo;

UPDATE prestamos
SET
    cuotas = 12,
    interes_anual = 18,
    total_pagar = monto + (monto * 0.18),
    cuota_mensual = (monto + (monto * 0.18)) / 12,
    estado_acuerdo = 'Pendiente'
WHERE cuotas IS NULL;



-- GARANTIAS: activo digital, documentos y evaluacion


ALTER TABLE garantias
ADD COLUMN nombre_activo VARCHAR(150) NULL AFTER tipo,
ADD COLUMN correo_titular VARCHAR(150) NULL AFTER identificador,
ADD COLUMN fecha_inicio VARCHAR(50) NULL AFTER correo_titular,
ADD COLUMN ingresos_mensuales DOUBLE NULL AFTER valor_estimado,
ADD COLUMN identificacion_personal VARCHAR(1000) NULL AFTER ingresos_mensuales,
ADD COLUMN documentacion_personal VARCHAR(1000) NULL AFTER identificacion_personal,
ADD COLUMN historial_crediticio VARCHAR(1000) NULL AFTER documentacion_personal,
ADD COLUMN comprobantes_ingresos VARCHAR(1000) NULL AFTER historial_crediticio,
ADD COLUMN comprobante_activo VARCHAR(1000) NULL AFTER comprobantes_ingresos,
ADD COLUMN puntuacion INT NULL AFTER estado,
ADD COLUMN nivel_riesgo VARCHAR(50) NULL AFTER puntuacion,
ADD COLUMN recomendacion VARCHAR(100) NULL AFTER nivel_riesgo,
ADD COLUMN resultado_evaluacion TEXT NULL AFTER recomendacion;


